{% extends 'base.html.twig' %}

{% block body %}
<h1>Administration</h1>

<div class="row mt-4 mb-4">
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-user"></i> Utilisateurs
                </h5>
                <p class="card-text">Gérer les utilisateurs</p>
                <a href="{{ path('app_admin_user') }}" class="btn btn-primary">
                    Liste des utilisateurs
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-users"></i> Groupes
                </h5>
                <p class="card-text">Gérer les groupes</p>
                <a href="{{ path('app_admin_group_list') }}" class="btn btn-primary">
                    Liste des groupes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-cog"></i> Configuration
                </h5>
                <p class="card-text">Paramètres globaux</p>
                <a href="{{ path('app_admin_config') }}" class="btn btn-primary">
                    Configuration
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-palette"></i> Thèmes
                </h5>
                <p class="card-text">Choisir un thème de couleurs</p>
                <a href="{{ path('app_admin_theme') }}" class="btn btn-primary">
                    Thèmes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-image"></i> Icônes
                </h5>
                <p class="card-text">Gérer les icônes globales</p>
                <a href="{{ path('app_admin_icon_list') }}" class="btn btn-primary">
                    Icônes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-file"></i> Pages
                </h5>
                <p class="card-text">Gérer les pages et leurs widgets</p>
                <a href="{{ path('app_admin_page_list') }}" class="btn btn-primary">
                    Pages
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-th-list"></i> Items
                </h5>
                <p class="card-text">Gérer les catégories et items</p>
                <a href="{{ path('app_admin_itemcategory_list') }}" class="btn btn-primary">
                    Items
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-newspaper"></i> Blogs
                </h5>
                <p class="card-text">Gérer les blogs et articles</p>
                <a href="{{ path('app_admin_blog_list') }}" class="btn btn-primary">
                    Blogs
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}