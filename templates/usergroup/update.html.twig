{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

{% if routecancel is defined %}
    <a href="{{ path(routecancel) }}" class="btn btn-secondary mb-3">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
{% endif %}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Utilisateurs non membres</h5>
            </div>
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0" id="tableNotInGroup">
                        <thead>
                            <tr>
                                <th>Actions</th>
                                <th>Nom d'utilisateur</th>
                                <th>Email</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in usersNotInGroup %}
                            <tr>
                                <td>
                                    <a href="{{ path(routeupdate, {id: group.id, action: 'add', userId: user.id}) }}" class="btn btn-sm btn-success" title="Ajouter">
                                        <i class="fas fa-plus"></i>
                                    </a>
                                </td>
                                <td>{{ user.displayName }}</td>
                                <td>{{ user.email }}</td>
                            </tr>
                            {% else %}
                            <tr>
                                <td></td>
                                <td class="text-center">Aucun utilisateur disponible</td>
                                <td></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Membres du groupe</h5>
            </div>
            <div class="card-body p-3">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0" id="tableInGroup">
                        <thead>
                            <tr>
                                <th>Actions</th>
                                <th>Nom d'utilisateur</th>
                                <th>Email</th>
                                <th>Rôle</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for ug in userGroups %}
                            <tr>
                                <td>
                                    <a href="{{ path(routeupdate, {id: group.id, action: 'remove', userId: ug.user.id}) }}" class="btn btn-sm btn-danger" title="Retirer">
                                        <i class="fas fa-minus"></i>
                                    </a>
                                </td>
                                <td>{{ ug.user.displayName }}</td>
                                <td>{{ ug.user.email }}</td>
                                <td>
                                    <select onchange="window.location.href='{{ path(routeupdate, {id: group.id, action: 'setrole', userId: ug.user.id}) }}&role=' + this.value" class="form-select form-select-sm">
                                        <option value="MASTER" {{ ug.role == 'MASTER' ? 'selected' : '' }}>MASTER</option>
                                        <option value="USER" {{ ug.role == 'USER' ? 'selected' : '' }}>USER</option>
                                        <option value="VIEWER" {{ ug.role == 'VIEWER' ? 'selected' : '' }}>VIEWER</option>
                                    </select>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td></td>
                                <td class="text-center">Aucun membre</td>
                                <td></td>
                                <td></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    $('#tableNotInGroup').DataTable({
        order: [[1, 'asc']],
        columnDefs: [
            { orderable: false, targets: [0] }
        ]
    });
    $('#tableInGroup').DataTable({
        order: [[1, 'asc']],
        columnDefs: [
            { orderable: false, targets: [0, 3] }
        ]
    });
});
</script>
{% endblock %}