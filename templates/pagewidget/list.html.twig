{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

<div class="d-flex gap-2 mb-3">
    <button type="button" class="btn btn-primary" id="btn-add-widget">
        <i class="fas fa-plus"></i> Ajouter un Widget
    </button>
    {% if admin is defined and admin %}
        <a href="{{ path('app_admin_page_update', {id: page.id}) }}" class="btn btn-outline-secondary">
            <i class="fas fa-edit"></i> Modifier la page
        </a>
        <a href="{{ path('app_admin_page_view', {slug: page.slug}) }}" class="btn btn-secondary">
            <i class="fas fa-eye"></i> Voir la page
        </a>
    {% else %}
        <a href="{{ path('app_user_page_update', {id: page.id}) }}" class="btn btn-outline-secondary">
            <i class="fas fa-edit"></i> Modifier la page
        </a>
        <a href="{{ path('app_user_page_view', {slug: page.slug}) }}" class="btn btn-secondary">
            <i class="fas fa-eye"></i> Voir la page
        </a>
    {% endif %}
</div>

<div id="grid-container">
    {{ page.pageTemplate.template|raw }}
</div>

<div id="page-widgets-data" style="display:none;">
    {% for widget in widgets|sort((a, b) => a.widgetOrder <=> b.widgetOrder) %}
        <div class="card mb-2 widget-card" id="widget-{{ widget.id }}"
             data-widget-id="{{ widget.id }}"
             data-location="{{ widget.location|default('') }}"
             data-widget-order="{{ widget.widgetOrder|default(0) }}">
            <div class="card-body p-2">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        {% if widget.icon %}
                            <img src="/{{ widget.icon.route }}" alt="" style="height: 32px; width: 32px; object-fit: contain; vertical-align: middle; margin-right: 6px;">
                        {% endif %}
                        <strong>{{ widget.widget.title }}</strong>
                        {% if widget.title %}
                            <span class="text-muted ms-1">&middot; {{ widget.title }}</span>
                        {% endif %}
                    </div>
                    <div class="d-flex gap-1 ms-2">
                        <a href="{{ path(routeupdate, {pageId: page.id, id: widget.id}) }}"
                           class="btn btn-sm btn-secondary" title="Modifier">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button class="btn btn-sm btn-danger btn-delete-widget" data-widget-id="{{ widget.id }}" title="Supprimer">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

<div class="modal fade" id="widgetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter un Widget</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" id="widgetModalBody">
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block localstyle %}
<style>
    #grid-container {
        padding: 0;
        margin: 0;
    }
    .grid-cell {
        min-height: 80px;
        padding: 0.5rem;
        border: 2px dashed var(--app-bs-header);
        border-radius: 8px;
        transition: all 0.2s ease;
        position: relative;
        background: rgba(var(--bs-primary-rgb), 0.03);
    }
    .grid-cell.drag-over {
        border-color: var(--app-bs-header);
        background: rgba(var(--bs-primary-rgb), 0.08);
        box-shadow: inset 0 0 8px rgba(var(--bs-primary-rgb), 0.15);
    }
    .grid-cell.empty-cell::after {
        content: 'Glissez un widget ici';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--app-bs-header);
        opacity: 0.6;
        font-size: 12px;
        pointer-events: none;
    }
    .widget-card {
        cursor: grab;
        border-left: 4px solid var(--bs-primary);
        transition: box-shadow 0.2s ease;
        margin-bottom: 4px;
    }
    .widget-card:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }
</style>
{% endblock %}

{% block localscript %}
<script>
$(function() {
    var pageId = {{ page.id }};
    var moveUrl = '{{ path(routemove, {pageId: page.id, id: 0}) }}'.replace(/\/0$/, '');
    var submitUrl = '{{ path(routesubmit, {pageId: page.id}) }}';
    var deleteUrl = '{{ path(routedelete, {pageId: page.id, id: 0}) }}'.replace(/\/0$/, '');

    var $gridContainer = $('#grid-container');

    $gridContainer.find('[id^="R"][id*="C"]').each(function() {
        $(this).addClass('grid-cell').attr('data-location', this.id);
    });

    $('#page-widgets-data .widget-card').each(function() {
        var location = $(this).data('location');
        var $target = location ? $('#' + CSS.escape(location)) : null;
        if ($target && $target.length) {
            $target.append($(this));
        } else {
            $('#R1C1').append($(this));
        }
    });

    $('#page-widgets-data').remove();

    $gridContainer.find('.grid-cell').each(function() {
        if (!$(this).find('.widget-card').length) {
            $(this).addClass('empty-cell');
        }
    });

    $gridContainer.find('.widget-card').draggable({
        helper: 'clone',
        revert: 'invalid',
        zIndex: 1000,
        cursor: 'grabbing',
        start: function() {
            $(this).css('opacity', '0.4');
        },
        stop: function() {
            $(this).css('opacity', '1');
        }
    });

    $gridContainer.find('.grid-cell').droppable({
        accept: '.widget-card',
        over: function() {
            $(this).addClass('drag-over');
        },
        out: function() {
            $(this).removeClass('drag-over');
        },
        drop: function(event, ui) {
            $(this).removeClass('drag-over');

            var $original = ui.draggable;
            var widgetId = $original.data('widget-id');
            var newLocation = $(this).data('location');

            if (!widgetId || !newLocation) return;

            // Move widget first
            $original.appendTo(this);
            $original.attr('data-location', newLocation);
            $original.find('.location-label').text(newLocation);

            // Collect all widgets in the target cell with their new orders
            var widgets = [];
            $(this).find('.widget-card').each(function(index) {
                widgets.push({
                    id: $(this).data('widget-id'),
                    location: newLocation,
                    widgetOrder: index
                });
            });

            $.ajax({
                url: moveUrl + '/' + widgetId,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ location: newLocation, widgetOrder: widgets[0].widgetOrder, widgets: widgets }),
                success: function(response) {
                    if (response.success) {
                        updateEmptyCells();
                        showToast('Widget déplacé vers ' + newLocation, 'success');
                    }
                }.bind(this),
                error: function() {
                    showToast('Erreur lors du déplacement', 'danger');
                }
            });
        }
    });

    function updateEmptyCells() {
        $gridContainer.find('.grid-cell').each(function() {
            if (!$(this).find('.widget-card').length) {
                $(this).addClass('empty-cell');
            } else {
                $(this).removeClass('empty-cell');
            }
        });
    }

    function showToast(message, type) {
        var $container = $('.toast-container');
        if (!$container.length) {
            $container = $('<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>').appendTo('body');
        }
        var $toast = $('<div class="toast align-items-center text-bg-' + type + ' border-0 show" role="alert"></div>');
        $toast.html('<div class="d-flex"><div class="toast-body">' + message + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>');
        $container.append($toast);
        setTimeout(function() { $toast.remove(); }, 3000);
    }

    $('#btn-add-widget').on('click', function() {
        var modal = new bootstrap.Modal(document.getElementById('widgetModal'));
        $('#widgetModalBody').html('<div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>');
        modal.show();

        $.get(submitUrl + '?partial=1', function(html) {
            $('#widgetModalBody').html(html);

            // Click on widget card = submit
            $(document).off('click', '.widget-select-card').on('click', '.widget-select-card', function() {
                var value = $(this).data('value');
                var $form = $('#widget-select-form');
                $form.find('input[name="page_widget[widget]"]').val(value);

                fetch($form.attr('action') + '?partial=1', {
                    method: 'POST',
                    body: new FormData($form[0]),
                    credentials: 'same-origin'
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data && data.redirect) {
                        modal.hide();
                        window.location.href = data.redirect;
                    }
                })
                .catch(function() {
                    showToast('Erreur lors de la sauvegarde', 'danger');
                });
            });
        });
    });

    $(document).on('click', '.btn-delete-widget', function() {
        var $btn = $(this);
        var widgetId = $btn.data('widget-id');
        var widgetName = $btn.closest('.widget-card').find('strong').text();

        if (!confirm('Supprimer le widget « ' + widgetName + ' » ?')) {
            return;
        }

        $.ajax({
            url: deleteUrl + '/' + widgetId,
            type: 'GET',
            success: function() {
                $btn.closest('.widget-card').fadeOut(300, function() {
                    $(this).remove();
                    updateEmptyCells();
                });
                showToast('Widget supprimé', 'success');
            },
            error: function() {
                showToast('Erreur lors de la suppression', 'danger');
            }
        });
    });
});
</script>
{% endblock %}
