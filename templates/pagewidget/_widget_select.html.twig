{% do form_widget(form.widget) %}
{{ form_start(form, {'attr': {'id': 'widget-select-form', 'action': form_action}}) }}
    <input type="hidden" name="{{ form.widget.vars.full_name }}" id="{{ form.widget.vars.id }}" value="">
    <div class="d-flex flex-wrap gap-2" id="widget-select-grid">
        {% for choice in form.widget.vars.choices %}
            <div class="widget-select-card card" data-value="{{ choice.value }}" style="cursor: pointer; min-width: 140px;">
                <div class="card-body p-2 text-center">
                    {% if choice.data.icon %}
                        <img src="/{{ choice.data.icon.route }}" alt="" style="height: 32px; width: 32px; object-fit: contain; margin-bottom: 4px;">
                    {% endif %}
                    <div class="small fw-semibold">{{ choice.data.title }}</div>
                </div>
            </div>
        {% endfor %}
    </div>
{{ form_end(form) }}
