{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

{% if routesubmit is defined %}
    <div class="d-flex gap-2 mb-3">
        <a href="{{ path(routesubmit) }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouveau Blog
        </a>
    </div>
{% endif %}

<div class="card">
    <div class="card-body p-3">
        <div class="table-responsive">
        <table class="table table-striped table-bordered mb-0" id="table">
            <thead>
                <tr>
                    <th class="text-nowrap" data-orderable="false" width="120px">Actions</th>
                    <th>Titre</th>
                    <th>Slug</th>
                    <th>Articles</th>
                    <th>Groupes</th>
                </tr>
            </thead>
            <tbody>
                {% for blog in blogs %}
                    <tr>
                        <td class="text-nowrap">
                            <a href="{{ path(isAdmin ? 'app_admin_blog_view' : 'app_blog_view', {slug: blog.slug}) }}" class="btn btn-sm btn-primary" title="Voir">
                                <i class="fas fa-eye"></i>
                            </a>
                            {% if is_granted('blog_edit', blog) %}
                            <a href="{{ path(routeupdate, {id: blog.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                            {% endif %}
                        </td>
                        <td><strong>{{ blog.title }}</strong></td>
                        <td>{{ blog.slug }}</td>
                        <td>{{ blog.articles|length }}</td>
                        <td>
                            {% for group in blog.groups %}
                                <span class="badge bg-info">{{ group.name }}</span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endfor %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted">Aucun blog trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    var $table = $('#table');
    if ($table.find('tbody tr').length > 1 || $table.find('tbody td[colspan]').length === 0) {
        $table.DataTable({
            order: [[1, 'asc']]
        });
    }
});
</script>
{% endblock %}
