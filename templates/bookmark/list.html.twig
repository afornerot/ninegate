{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

<div class="d-flex gap-2 mb-3">
    <a href="{{ path('app_user_bookmark_submit') }}" class="btn btn-primary">
        <i class="fas fa-plus"></i> Ajouter
    </a>
</div>

<div class="card">
    <div class="card-body p-3">
        <div class="table-responsive">
        <table class="table table-striped table-bordered mb-0">
            <thead>
                <tr>
                    <th class="text-nowrap" width="100px">Actions</th>
                    <th>Icône</th>
                    <th>Titre</th>
                    <th>Résumé</th>
                    <th>Lien</th>
                </tr>
            </thead>
            <tbody>
                {% for bookmark in bookmarks %}
                    <tr>
                        <td class="text-nowrap">
                            <a href="{{ path('app_user_bookmark_update', {id: bookmark.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="{{ path('app_user_bookmark_delete', {id: bookmark.id}) }}" class="btn btn-sm btn-danger" title="Supprimer" onclick="return confirm('Supprimer ce favori ?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                        <td>
                            {% if bookmark.icon %}
                                <img src="/{{ bookmark.icon.route }}" alt="" style="height: 24px; width: 24px; object-fit: contain;">
                            {% endif %}
                        </td>
                        <td>{{ bookmark.title }}</td>
                        <td>{{ bookmark.summary|default('-') }}</td>
                        <td>{% if bookmark.url %}<a href="{{ bookmark.url }}" target="_blank">{{ bookmark.url }}</a>{% else %}-{% endif %}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted">Aucun favori</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}
