{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>
{% if routesubmit is defined and is_granted('group_create') %}
    <a href="{{ path(routesubmit) }}" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Ajouter
    </a>
{% endif %}
{% if routesubscribe is defined and routesubscribe %}
    <a href="{{ path(routesubscribe) }}" class="btn btn-success mb-3">
        <i class="fas fa-search"></i> Groupes Disponibles
    </a>
{% endif %}

<div class="card">
    <div class="card-body p-3">
        <div class="table-responsive">
        <table class="table table-striped table-bordered mb-0" id="table">
            <thead>
                <tr>
                    <th class="text-nowrap" data-orderable="false" width="100px">Actions</th>
                    <th class="text-nowrap" data-orderable="false" width="100px">Logo</th>
                    <th class="text-nowrap">Nom</th>
                    <th>Description</th>
                    <th>{{ admin ? 'Type' : 'Rôle' }}</th>
                </tr>
            </thead>
            <tbody>
                {% for group in groups %}
                <tr>
                    <td class="text-nowrap">
                        {% if is_granted('group_edit', group) %}
                            <a href="{{ path(routeupdate, {id: group.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="{{ path(routeusergroup, {id: group.id}) }}" class="btn btn-sm btn-info" title="Gérer les utilisateurs">
                                <i class="fas fa-users"></i>
                            </a>
                        {% endif %}
                        {% if not admin and group.isOpen and routeleave %}
                            <a href="{{ path(routeleave, {id: group.id}) }}" class="btn btn-sm btn-warning" title="Quitter" onclick="return confirm('Voulez-vous quitter ce groupe ?')">
                                <i class="fas fa-sign-out-alt"></i>
                            </a>
                        {% endif %}
                    </td>
                    <td>
                        <img src="{{ asset(group.logo) }}" alt="Logo" style="width: 32px; height: 32px; object-fit: cover;">
                    </td>
                    <td>{{ group.name }}</td>
                    <td>{{ group.description }}</td>
                    <td>{{ admin ? group.type : (group.isOpen ? 'Ouvert' : 'Fermé') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    $('#table').DataTable({
        order: [[2, 'asc']]
    });
});
</script>
{% endblock %}