{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

<a href="{{ path(routecancel) }}" class="btn btn-secondary mb-3">Retour</a>

{% if groups is empty %}
    <div class="alert alert-info">Aucun groupe disponible pour l'instant.</div>
{% else %}
<div class="card">
    <div class="card-body p-3">
        <div class="table-responsive">
        <table class="table table-striped table-bordered mb-0" id="table">
            <thead>
                <tr>
                    <th class="text-nowrap" width="100px">Action</th>
                    <th class="text-nowrap" width="100px">Logo</th>
                    <th class="text-nowrap">Nom</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                {% for group in groups %}
                <tr>
                    <td class="text-nowrap">
                        <a href="{{ path(routejoin, {id: group.id}) }}" class="btn btn-sm btn-success" title="Rejoindre">
                            <i class="fas fa-plus"></i>
                        </a>
                    </td>
                    <td>
                        <img src="{{ asset(group.logo) }}" alt="Logo" style="width: 32px; height: 32px; object-fit: cover;">
                    </td>
                    <td>{{ group.name }}</td>
                    <td>{{ group.description }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    $('#table').DataTable({
        order: [[2, 'asc']]
    });
});
</script>
{% endblock %}