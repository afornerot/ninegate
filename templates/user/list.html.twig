{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>
{% if routesubmit is defined %}
    <a href="{{ path(routesubmit) }}" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Ajouter
    </a>
{% endif %}

<div class="card">
        <div class="card-body p-3">
            <div class="table-responsive">
            <table class="table table-striped table-bordered mb-0" id="table">
                <thead>
                    <tr>
                        <th class="text-nowrap" data-orderable="false" width="100px">Actions</th>
                        <th class="text-nowrap" data-orderable="false" width="100px">Avatar</th>
                        <th>Login</th>
                        <th>Email</th>
                        <th>Roles</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td class="text-nowrap">
                            {% if routeupdate is defined %}
                                <a href="{{ path(routeupdate, {id: user.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                            {% endif %}
                            {% if routedelete is defined and user.id != app.user.id %}
                                <a href="{{ path(routedelete, {id: user.id}) }}" class="btn btn-sm btn-danger" title="Supprimer" onclick="return confirm('Voulez-vous supprimer cet utilisateur ?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            {% endif %}
                        </td>
                        <td>
                            <img src="{{ asset(user.avatar) }}" alt="Avatar" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;background-color: var(--bs-dark);">
                        </td>
                        <td>{{ user.displayName }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.roles|join(', ') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        </div>
    </div>
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    $('#table').DataTable({
        order: [[2, 'asc']]
    });
});
</script>
{% endblock %}