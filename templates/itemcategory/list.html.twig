{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>

<div class="d-flex gap-2 mb-3">
    <a href="{{ path('app_admin_itemcategory_submit') }}" class="btn btn-primary">
        <i class="fas fa-plus"></i> Catégorie
    </a>
</div>

<div id="category-sortable">
    {% for category in categories %}
        <div class="card mb-3 category-card" data-category-id="{{ category.id }}">
            <div class="card-header d-flex align-items-center justify-content-between p-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-grip-vertical text-muted" style="cursor: grab;"></i>
                    <strong>{{ category.title }}</strong>
                    <span class="badge bg-secondary">{{ category.items|length }}</span>
                </div>
                <div class="d-flex gap-1">
                    <a href="{{ path('app_admin_item_submit', {categoryId: category.id}) }}" class="btn btn-sm btn-success" title="Ajouter un item">
                        <i class="fas fa-plus"></i>
                    </a>
                    <a href="{{ path('app_admin_itemcategory_update', {id: category.id}) }}" class="btn btn-sm btn-secondary" title="Modifier la catégorie">
                        <i class="fas fa-edit"></i>
                    </a>
                    <a href="{{ path('app_admin_itemcategory_delete', {id: category.id}) }}" class="btn btn-sm btn-danger" title="Supprimer la catégorie" onclick="return confirm('Supprimer cette catégorie et tous ses items ?')">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            </div>
            <div class="card-body p-2 item-drop-zone" data-category-id="{{ category.id }}">
                {% for item in category.items %}
                    <div class="card mb-1 item-card" data-item-id="{{ item.id }}" data-category-id="{{ category.id }}"
                         style="{% if item.bgcolor %}background-color: {{ item.bgcolor }};{% endif %}{% if item.color %} color: {{ item.color }};{% endif %}">
                        <div class="card-body p-2 d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2 flex-grow-1">
                                <i class="fas fa-grip-vertical text-muted item-handle" style="cursor: grab;"></i>
                                {% if item.icon %}
                                    <img src="/{{ item.icon.route }}" alt="" style="height: 24px; width: 24px; object-fit: contain;">
                                {% endif %}
                                <div>
                                    <strong>{{ item.title }}</strong>
                                    {% if item.summary %}
                                        <span class="text-muted ms-1">&middot; {{ item.summary }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                {% if item.url %}
                                    <a href="{{ item.url }}" target="{{ item.newTab ? '_blank' : '_self' }}" class="btn btn-sm btn-outline-primary" title="Ouvrir le lien">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                {% endif %}
                                {% if item.description %}
                                    <button class="btn btn-sm btn-outline-info item-info-btn" title="Voir la description" data-description="{{ item.description|e('html_attr') }}">
                                        <i class="fas fa-info"></i>
                                    </button>
                                {% endif %}
                                <a href="{{ path('app_admin_item_update', {categoryId: category.id, id: item.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="{{ path('app_admin_item_delete', {categoryId: category.id, id: item.id}) }}" class="btn btn-sm btn-danger" title="Supprimer" onclick="return confirm('Supprimer cet item ?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                {% if category.items|length == 0 %}
                    <p class="text-muted small mb-0 p-1 empty-msg">Aucun item. <a href="{{ path('app_admin_item_submit', {categoryId: category.id}) }}">Ajouter</a></p>
                {% endif %}
            </div>
        </div>
    {% else %}
        <p class="text-muted">Aucune catégorie. Créez-en une pour commencer.</p>
    {% endfor %}
</div>

{# Info modal #}
<div class="modal fade" id="itemInfoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Description</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" id="itemInfoContent"></div>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
$(function() {
    var reorderCategoryUrl = '{{ path("app_admin_itemcategory_reorder") }}';
    var moveItemUrl = '{{ path("app_admin_item_move", {id: 0}) }}'.replace(/\/0$/, '');

    // Category sortable
    $('#category-sortable').sortable({
        handle: '.card-header .fa-grip-vertical',
        items: '> .category-card',
        cancel: '.item-drop-zone, .item-drop-zone *',
        placeholder: 'ui-state-highlight',
        update: function() {
            var order = [];
            $('#category-sortable .category-card').each(function() {
                order.push($(this).data('category-id'));
            });
            $.ajax({
                url: reorderCategoryUrl,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ order: order }),
                success: function() { showToast('Ordre sauvegardé', 'success'); },
                error: function() { showToast('Erreur', 'danger'); }
            });
        }
    });

    // Item draggable
    $('.item-card').draggable({
        handle: '.item-handle',
        helper: 'clone',
        revert: 'invalid',
        zIndex: 1000,
        cursor: 'grabbing',
        start: function() { $(this).css('opacity', '0.4'); },
        stop: function() { $(this).css('opacity', '1'); }
    });

    // Category body = drop zone for items
    $('.item-drop-zone').droppable({
        accept: '.item-card',
        tolerance: 'pointer',
        over: function() { $(this).css('background', 'rgba(var(--bs-primary-rgb), 0.08)'); },
        out: function() { $(this).css('background', ''); },
        drop: function(event, ui) {
            $(this).css('background', '');

            var $item = ui.draggable;
            var itemId = $item.data('item-id');
            var newCategoryId = $(this).data('category-id');
            var oldCategoryId = $item.data('category-id');

            // Calculate order based on drop position
            var order = 0;
            var $items = $(this).find('.item-card');
            var dropY = ui.offset.top + ui.helper.height() / 2;

            $items.each(function(i) {
                var rect = this.getBoundingClientRect();
                if (dropY > rect.top + rect.height / 2) {
                    order = i + 1;
                }
            });

            // Move DOM element
            var $clone = $item.clone().css({opacity: '1', position: '', top: '', left: ''});
            if (order >= $items.length) {
                $(this).append($clone);
            } else {
                $items.eq(order).before($clone);
            }
            $item.remove();

            // Re-init draggable on cloned element
            $clone.draggable({
                handle: '.item-handle',
                helper: 'clone',
                revert: 'invalid',
                zIndex: 1000,
                cursor: 'grabbing',
                start: function() { $(this).css('opacity', '0.4'); },
                stop: function() { $(this).css('opacity', '1'); }
            });
            $clone.data('category-id', newCategoryId);

            // Remove empty message if present
            $(this).find('.empty-msg').remove();

            // AJAX
            $.ajax({
                url: moveItemUrl + '/' + itemId,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ categoryId: newCategoryId, order: order }),
                success: function() { showToast('Item déplacé', 'success'); },
                error: function() { showToast('Erreur', 'danger'); }
            });
        }
    });

    // Info button
    $(document).on('click', '.item-info-btn', function() {
        var desc = $(this).data('description');
        $('#itemInfoContent').text(desc);
        new bootstrap.Modal(document.getElementById('itemInfoModal')).show();
    });

    function showToast(message, type) {
        var $container = $('.toast-container');
        if (!$container.length) {
            $container = $('<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>').appendTo('body');
        }
        var $toast = $('<div class="toast align-items-center text-bg-' + type + ' border-0 show" role="alert"></div>');
        $toast.html('<div class="d-flex"><div class="toast-body">' + message + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>');
        $container.append($toast);
        setTimeout(function() { $toast.remove(); }, 3000);
    }
});
</script>
{% endblock %}
