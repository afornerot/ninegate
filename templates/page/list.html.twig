{% extends 'base.html.twig' %}

{% block body %}
<h1>{{ title }}</h1>
{% if routesubmit is defined %}
    <a href="{{ path(routesubmit) }}" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Ajouter
    </a>
{% endif %}

<div class="card">
    <div class="card-body p-3">
        <div class="table-responsive">
        <table class="table table-striped table-bordered mb-0" id="table">
            <thead>
                <tr>
                    <th class="text-nowrap" data-orderable="false" width="100px">Actions</th>
                    <th>Ordre</th>
                    <th>Titre</th>
                    <th>Slug</th>
                    <th>Groupes</th>
                    {% if admin is defined and admin %}
                    <th>Rôles</th>
                    <th>Utilisateur</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for page in pages %}
                    {% if is_granted('page_edit', page) %}
                        <tr>
                            <td class="text-nowrap">
                                <a href="{{ path(routeupdate, {id: page.id}) }}" class="btn btn-sm btn-secondary" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="{{ path(isAdmin ? 'app_admin_pagewidget_list' : 'app_user_pagewidget_list', {pageId: page.id}) }}" class="btn btn-sm btn-info" title="Widgets">
                                    <i class="fas fa-cubes"></i>
                                </a>
                                <a href="{{ path(isAdmin ? 'app_admin_page_view' : 'app_user_page_view', {slug: page.slug}) }}" class="btn btn-sm btn-success" title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                            <td>{{ page.pageOrder }}</td>
                            <td>{{ page.title }}</td>
                            <td>{{ page.slug }}</td>
                            <td>
                                {% if page.groups|length > 0 %}
                                    {% for group in page.groups %}
                                        <span class="badge bg-info">{{ group.name }}</span>
                                    {% endfor %}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            {% if admin is defined and admin %}
                            <td>
                                {% if page.roles|length > 0 %}
                                    {% for role in page.roles %}
                                        <span class="badge bg-warning">{{ role }}</span>
                                    {% endfor %}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{{ page.user ? page.user.displayName : '-' }}</td>
                            {% endif %}
                        </tr>
                    {% endif %}
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
$(document).ready(function() {
    $('#table').DataTable({
        order: [[1, 'asc']]
    });
});
</script>
{% endblock %}